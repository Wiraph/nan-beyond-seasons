# OpenRouter — enables the real AI chat (/api/chat). Optional.
# Leave OPENROUTER_API_KEY blank to fall back to the built-in mock replies.
# Get a key: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Preferred model(s). Comma-separated = try in order until one is available
# (free :free endpoints are often rate-limited; the server also falls back
# through a built-in chain of free models, then to mock replies).
# Live free options seen recently:
#   google/gemma-4-26b-a4b-it:free           (default — fast, multilingual)
#   google/gemma-4-31b-it:free
#   nvidia/nemotron-3-super-120b-a12b:free
#   openai/gpt-oss-120b:free
#   meta-llama/llama-3.3-70b-instruct:free
#   qwen/qwen3-next-80b-a3b-instruct:free
OPENROUTER_MODEL=google/gemma-4-26b-a4b-it:free

# Optional ranking headers shown on openrouter.ai
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_APP_NAME=Nan Connect
